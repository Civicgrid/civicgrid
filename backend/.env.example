# CivicGrid Oracle — Environment Variables
# Copy this file to .env and fill in real values before running.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000

# ── Stellar Network ───────────────────────────────────────────────────────────
RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# ── Contract Addresses (filled in by deploy_org.sh) ──────────────────────────
CIVIC_ID_CONTRACT=
GRID_TRADE_CONTRACT=
GRID_DAO_CONTRACT=

# ── Oracle Keypair ────────────────────────────────────────────────────────────
# The admin account of the civic_id and grid_trade contracts.
# ⚠ Never commit this to version control.
ORACLE_SECRET_KEY=

# ── Admin token for privileged endpoints ─────────────────────────────────────
ORACLE_ADMIN_TOKEN=change-me-in-production

# ── Meter simulation interval (milliseconds) ─────────────────────────────────
METER_INTERVAL_MS=30000
